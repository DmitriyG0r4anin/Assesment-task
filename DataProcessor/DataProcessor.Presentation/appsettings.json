{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  },
  "MongoDb": {
    "ConnectionString": "mongodb://mongodb:27017",
    "DatabaseName": "data_metrics",
    "Collections": {
      "Rooms": "rooms",
      "Motions": "motions",
      "AirQualities": "air_qualities",
      "Energies": "energies"
    }
  },
  "Kafka": {
    "Brokers": "broker:29092",
    "Topic": "meter-data",
    "GroupId": "data-processor-group"
  }
}
