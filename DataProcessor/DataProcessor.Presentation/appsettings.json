{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "data_metrics"
  },
  "Kafka": {
    "Brokers": "broker:29092",
    "Topic": "meter-data",
    "GroupId": "data-processor-group"
  }
}
