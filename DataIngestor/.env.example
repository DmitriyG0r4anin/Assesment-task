WEAKAPP_URL=http://weak-app:8080
WEAKAPP_API_KEY=YOUR_SUPERSECRET_API_KEY

KAFKA_BROKERS=broker:9092
KAFKA_TOPIC=meter-data

POLL_INTERVAL=5m

# Optional tuning values (examples)
#REQUEST_TIMEOUT=30s
#MAX_RETRIES=5
#INITIAL_BACKOFF=1s
#MAX_BACKOFF=30s
#PRODUCER_RETRY_COUNT=5

# Notes:
# - For local testing with Docker Compose you might set:
#   KAFKA_BROKERS=localhost:29092
