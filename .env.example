## DataIngestor
# WeakApp configuration
WEAKAPP_URL=http://weak-app:8080
WEAKAPP_API_KEY=<YOUR_WEAKAPP_API_KEY>
# Kafka configuration (comma-separated list of brokers)
KAFKA_BROKERS=broker:29092
KAFKA_TOPIC=meter-data
KAFKA_MOTION_TOPIC=motion-events
# Polling and retry/timing settings (Go duration format)
POLL_INTERVAL=10s
REQUEST_TIMEOUT=30s
MAX_RETRIES=5
INITIAL_BACKOFF=1s
MAX_BACKOFF=30s